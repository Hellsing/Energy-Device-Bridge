{
  "release-type": "simple",
  "include-v-in-tag": false,
  "changelog-type": "github",
  "pull-request-title-pattern": "release${component} ${version}",
  "group-pull-request-title-pattern": "release${component} ${version}",
  "packages": {
    ".": {
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "json",
          "path": "custom_components/energy_device_bridge/manifest.json",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}
